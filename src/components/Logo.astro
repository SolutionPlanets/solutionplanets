---
import { SITE } from 'astrowind:config';
import { Image } from 'astro:assets';
import splogo from '~/assets/images/splogo.png';
---

<span class="self-center ml-2 rtl:ml-0 rtl:mr-2 flex items-center gap-2 text-2xl md:text-2xl font-bold text-gray-900 whitespace-nowrap dark:text-white">
  <Image src={splogo} alt={`${SITE?.name} logo`} width={57} height={57} class="w-[57px] h-[57px]" loading="eager"/>
  {SITE?.name}
</span>
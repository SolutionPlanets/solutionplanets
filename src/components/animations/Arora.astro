---
interface Props {
  className?: string;
}
const { className = '' } = Astro.props;
---

<canvas class={`aurora-canvas ${className}`} id="aurora-canvas" />

<script>
  const canvas = document.getElementById('aurora-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  let width: number, height: number;
  // eslint-disable-next-line @typescript-eslint/no-unused-vars
  let t = 0;

  function resize() {
    width = canvas.width = canvas.offsetWidth;
    height = canvas.height = canvas.offsetHeight;
  }

  window.addEventListener('resize', resize);
  resize();

  const bands = [
    { color: [249, 115, 22],  speed: 0.004,  amp: 0.15, freq: 1.2, phase: 0.0 },
    { color: [251, 146, 60],  speed: 0.003,  amp: 0.12, freq: 0.9, phase: 1.0 },
    { color: [234, 88,  12],  speed: 0.005,  amp: 0.18, freq: 1.5, phase: 2.1 },
    { color: [255, 170, 80],  speed: 0.0025, amp: 0.10, freq: 0.7, phase: 3.2 },
    { color: [200, 70,  10],  speed: 0.0045, amp: 0.14, freq: 1.1, phase: 4.5 },
  ];

  function draw() {
    ctx.clearRect(0, 0, width, height);
    t += 1;

    bands.forEach(band => {
      band.phase += band.speed;

      // Gradient fades in from left, peaks in middle, fades out right
      const gradient = ctx.createLinearGradient(0, 0, width, 0);
      const [r, g, b] = band.color;
      gradient.addColorStop(0,   `rgba(${r},${g},${b}, 0)`);
      gradient.addColorStop(0.3, `rgba(${r},${g},${b}, 0.45)`);
      gradient.addColorStop(0.7, `rgba(${r},${g},${b}, 0.35)`);
      gradient.addColorStop(1,   `rgba(${r},${g},${b}, 0)`);

      ctx.beginPath();

      const steps = 100;

      // Top edge of ribbon — left to right, horizontally centered with vertical wave
      for (let i = 0; i <= steps; i++) {
        const progress = i / steps;
        const x = progress * width;
        const baseY = height * 0.5;
        const wave = Math.sin(progress * Math.PI * 2 * band.freq + band.phase) * band.amp * height;
        const y = baseY + wave;
        // eslint-disable-next-line @typescript-eslint/no-unused-expressions
        i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
      }

      // Bottom edge — return path with ribbon thickness
      for (let i = steps; i >= 0; i--) {
        const progress = i / steps;
        const x = progress * width;
        const baseY = height * 0.5;
        const wave = Math.sin(progress * Math.PI * 2 * band.freq + band.phase) * band.amp * height;
        const thickness = (Math.sin(progress * Math.PI) * 0.10 + 0.03) * height;
        ctx.lineTo(x, baseY + wave + thickness);
      }

      ctx.closePath();
      ctx.fillStyle = gradient;
      ctx.fill();
    });

    requestAnimationFrame(draw);
  }

  draw();
</script>

<style>
  .aurora-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }
</style>
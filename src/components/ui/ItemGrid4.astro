---
import { Icon } from 'astro-icon/components';
import { twMerge } from 'tailwind-merge';
import type { ItemGrid4 as Props, ProjectItem, SolutionItem, PlatformItem } from '~/types';

const { items = [], columns = 3, variant = 'portfolio', classes = {} } = Astro.props;

function isProjectItem(item: ProjectItem | SolutionItem | PlatformItem): item is ProjectItem {
  return 'impact' in item;
}

function isPlatformItem(item: ProjectItem | SolutionItem | PlatformItem): item is PlatformItem {
  return 'href' in item && !('impact' in item);
}

const gridClass =
  variant === 'portfolio'
    ? columns === 3
      ? 'grid-cols-1 md:grid-cols-2 lg:grid-cols-3'
      : columns === 2
        ? 'grid-cols-1 sm:grid-cols-2'
        : 'grid-cols-1'
    : variant === 'platforms'
      ? columns === 3
        ? 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3'
        : columns === 2
          ? 'grid-cols-1 sm:grid-cols-2'
          : 'grid-cols-1'
      : 'grid-cols-1 sm:grid-cols-2';
---

{
  items && items.length > 0 && (
    <div class={twMerge(`grid gap-5 ${gridClass}`, classes?.container)}>
      {items.map((item) =>
        isPlatformItem(item) ? (
          <a
            href={item.href}
            target="_blank"
            rel="noopener noreferrer"
            class="group rounded-xl border border-slate-200 dark:border-slate-700 border-t-2 dark:border-b-orange-500 bg-white dark:bg-slate-900 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-300 p-6 flex flex-col gap-3"
          >
            <div class="flex items-center justify-between">
              <span class="text-xl font-extrabold text-slate-900 dark:text-white tracking-tight">{item.title}</span>
              <svg class="w-4 h-4 text-slate-400 group-hover:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
              </svg>
            </div>
            <p class="text-xs font-semibold uppercase tracking-wider text-primary">{item.category}</p>
            <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{item.description}</p>
          </a>
        ) : isProjectItem(item) ? (
          <div class="group rounded-xl border border-slate-200 dark:border-slate-700 border-t-2 dark:border-b-orange-500 bg-white dark:bg-slate-900 shadow-sm hover:shadow-lg transition-all duration-300 p-6 flex flex-col gap-4 hover:-translate-y-0.5">
            <div class="flex items-start justify-between gap-3">
              <h3 class="text-[20px] font-semibold text-slate-900 dark:text-white leading-relaxed flex-1">{item.title}</h3>
              <span class="inline-block text-[10px] font-semibold uppercase tracking-wider text-primary bg-primary/10 rounded-full px-2.5 py-1 whitespace-nowrap flex-shrink-0">
                {item.category}
              </span>
            </div>
            <p class="text-slate-600 dark:text-slate-300 text-base leading-relaxed">
              <span class="text-primary font-bold mr-1">→</span>
              {item.description}
            </p>
            <div class="mt-auto pt-4 border-t border-slate-100 dark:border-slate-700/60">
              <p class="text-[10px] font-bold uppercase tracking-widest text-slate-400 dark:text-slate-500 mb-2.5">Impact</p>
              <ul class="space-y-1.5">
                {item.impact.map((point) => (
                  <li class="flex items-start gap-2 text-[14px] text-slate-600 dark:text-slate-300">
                    <Icon name="tabler:check" class="w-3.5 h-3.5 text-emerald-500 flex-shrink-0 mt-0.5" stroke-width={2.5} />
                    <span>{point}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ) : (
          <div class="rounded-xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-orange-500 p-6 flex items-center gap-5 shadow-sm hover:shadow-md transition-shadow">
            <div
              class={twMerge(
                'w-12 h-12 rounded-lg flex items-center justify-center flex-shrink-0',
                item.iconBgClass
              )}
            >
              <Icon name={item.icon} class={twMerge('w-6 h-6', item.iconColorClass)} stroke-width={1.5} />
            </div>
            <div>
              <p class="text-sm text-slate-400 dark:text-slate-500 line-through mb-0.5">{item.before}</p>
              <div class="flex items-center gap-2">
                <span class="text-primary font-bold text-lg leading-none">→</span>
                <p class="font-bold text-slate-900 dark:text-white text-base">{item.after}</p>
              </div>
            </div>
          </div>
        )
      )}
    </div>
  )
}

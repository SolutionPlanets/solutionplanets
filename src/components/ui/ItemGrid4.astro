---
import { Icon } from 'astro-icon/components';
import { twMerge } from 'tailwind-merge';

interface ProjectItem {
  title: string;
  category: string;
  description: string;
  impact: string[];
}

interface SolutionItem {
  icon: string;
  iconBgClass: string;
  iconColorClass: string;
  before: string;
  after: string;
}

interface Props {
  items?: (ProjectItem | SolutionItem)[];
  columns?: number;
  variant?: 'portfolio' | 'solutions';
  classes?: {
    container?: string;
  };
}

const { items = [], columns = 3, variant = 'portfolio', classes = {} } = Astro.props;

function isProjectItem(item: ProjectItem | SolutionItem): item is ProjectItem {
  return 'impact' in item;
}

const gridClass =
  variant === 'portfolio'
    ? columns === 3
      ? 'grid-cols-1 md:grid-cols-2 lg:grid-cols-3'
      : columns === 2
        ? 'grid-cols-1 sm:grid-cols-2'
        : 'grid-cols-1'
    : 'grid-cols-1 sm:grid-cols-2';
---

{
  items && items.length > 0 && (
    <div class={twMerge(`grid gap-5 ${gridClass}`, classes?.container)}>
      {items.map((item) =>
        isProjectItem(item) ? (
          <div class="group rounded-xl border border-slate-200 dark:border-slate-700 border-t-2 dark:border-b-orange-500 bg-white dark:bg-slate-900 shadow-sm hover:shadow-lg transition-all duration-300 p-6 flex flex-col gap-4 hover:-translate-y-0.5">
            <div class="flex items-start justify-between gap-3">
              <h3 class="text-[15px] font-bold text-slate-900 dark:text-white leading-snug flex-1">{item.title}</h3>
              <span class="inline-block text-[10px] font-semibold uppercase tracking-wider text-primary bg-primary/10 rounded-full px-2.5 py-1 whitespace-nowrap flex-shrink-0">
                {item.category}
              </span>
            </div>
            <p class="text-slate-600 dark:text-slate-300 text-sm leading-relaxed">
              <span class="text-primary font-bold mr-1">→</span>
              {item.description}
            </p>
            <div class="mt-auto pt-4 border-t border-slate-100 dark:border-slate-700/60">
              <p class="text-[10px] font-bold uppercase tracking-widest text-slate-400 dark:text-slate-500 mb-2.5">Impact</p>
              <ul class="space-y-1.5">
                {item.impact.map((point) => (
                  <li class="flex items-start gap-2 text-[13px] text-slate-600 dark:text-slate-300">
                    <Icon name="tabler:check" class="w-3.5 h-3.5 text-emerald-500 flex-shrink-0 mt-0.5" stroke-width={2.5} />
                    <span>{point}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ) : (
          <div class="rounded-xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 p-6 flex items-center gap-5 shadow-sm hover:shadow-md transition-shadow">
            <div
              class={twMerge(
                'w-12 h-12 rounded-lg flex items-center justify-center flex-shrink-0',
                item.iconBgClass
              )}
            >
              <Icon name={item.icon} class={twMerge('w-6 h-6', item.iconColorClass)} stroke-width={1.5} />
            </div>
            <div>
              <p class="text-sm text-slate-400 dark:text-slate-500 line-through mb-0.5">{item.before}</p>
              <div class="flex items-center gap-2">
                <span class="text-primary font-bold text-lg leading-none">→</span>
                <p class="font-bold text-slate-900 dark:text-white text-base">{item.after}</p>
              </div>
            </div>
          </div>
        )
      )}
    </div>
  )
}

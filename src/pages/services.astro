---
import Layout from '~/layouts/PageLayout.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Content1 from '~/components/widgets/Content1.astro';

const metadata = {
  title: 'Services - Solution Planets',
};
---

<Layout metadata={metadata}>
  <!-- Hero2 Widget ******************* -->

  <Hero2
    tagline="Our Services"
    actions={[
      { variant: 'primary',
        text: "Talk to an Expert",
        href: 'https://wa.me/918104664284',
        target: '_blank',
        icon: 'tabler:brand-whatsapp', 
    },
      { text: 'Explore Services', href: '#features2' },
    ]}
    
  >
    <Fragment slot="title">
      Engineering the Future, One <br />  <span class="text-accent dark:text-white">Solution</span> at a Time<br
      />
    </Fragment>

    <Fragment slot="subtitle">
      <span class="hidden sm:inline">
       From intelligent AI systems to 
       <span class="font-semibold">battle-hardened</span>cybersecurity — 
       </span
      >
      we build, protect, and scale your digital presence across every frontier of modern technology.
    </Fragment>
  </Hero2>

  <!-- Features2 Widget ************** -->

  <Features2
    id="features2"
    title="Built for the Intelligence Era"
    subtitle="Every service we offer is engineered to compound — your web presence, AI systems, security, and marketing working as one."
    columns={3}
    items={[
      {
        title: 'Custom Web Development',
        description:
          'We craft fast, accessible, and conversion-optimized websites — each built to your business requirements, not recycled from a template. Performance, Core Web Vitals, and mobile-first responsiveness are non-negotiables.',
        icon: 'tabler:brackets-angle',
        tags: ['Mobile Responsive','CMS integration', 'Headless architecture', 'Core Web Vitals', 'Accessibility (WCAG)'],
        callToAction: { text: 'Learn more →', href: '/services/custom-web-development' },
      },
      {
        title: 'Digital Product Engineering',
        description:
          'We design, build, and scale full-stack digital products — from MVPs to enterprise-grade platforms. Our engineering-first mindset means you get reliable architecture, clean code, and products that scale without drama.',
        icon: 'tabler:apps',
        tags: ['Saas development', 'API design', 'Microcervices', 'React/Next.js', 'Node/Python'],
        callToAction: { text: 'Learn more →', href: '/services/digital-product-engineering' },
      },
      {
        title: 'AI Integration & Automation',
        description: `We embed AI into the core of your business workflows as a force multiplier. From custom LLM-powered chatbots and AI copilots to predictive analytics pipelines, we automate repetitive work, surface insights, and deliver personalized experiences.`,
        icon: 'tabler:ai',
        tags: ['AI chatbots', 'LLM/RAG pipelines', 'Generative AI', 'Workflow automation'],
        callToAction: { text: 'Learn more →', href: '/services/ai-integration-automation' },
      },
      {
        title: 'AEO & SEO Strategy',
        description:
          'Beyond rankings — we optimize for Answer Engine Optimization (AEO), ensuring your brand surfaces inside AI-generated answers, voice search, and zero-click snippets. Combine that with technical SEO and content authority, and you dominate both Google and AI-powered search.',
        icon: 'tabler:list-search',
        tags: ['Technical SEO', 'AEO Engine', 'Content strategy', 'Link authority'],
        callToAction: { text: 'Learn more →', href: '/services/aeo-seo-strategy' },
      },
      {
        title: 'Digital Marketing & Growth',
        description:
          'We run data-driven marketing campaigns that go beyond vanity metrics. Performance marketing, AI-assisted content creation, email automation, and conversion rate optimization — all mapped to measurable business outcomes.',
        icon: 'tabler:businessplan',
        tags: ['CRO', 'AI content ops', 'Email automation', 'Performance marketing', 'Social strategy'],
        callToAction: { text: 'Learn more →', href: '/services/digital-marketing-growth' },
      },
      {
        title: 'Cybersecurity & VAPT',
        description:
          `In a world of accelerated threats, security can't be an afterthought. We conduct Vulnerability Assessment & Penetration Testing (VAPT), implement Zero Trust architectures, and deliver continuous compliance monitoring so your systems stay hardened and audit-ready.`,
        icon: 'tabler:shield-lock',
        tags: ['Zero Trust', 'Cloud security'],
        callToAction: { text: 'Learn more →', href: '/services/cybersecurity-vapt' },
      },
      {
        title: 'Ecommerce Solutions',
        description:
          'We build sophisticated B2B & B2C ecommerce platforms with multi-tiered pricing, bulk ordering, ERP/CRM integrations, and customer-specific catalogs. Designed to handle complex procurement workflows without friction.',
        icon: 'tabler:shopping-bag',
        tags: ['Custom storefront', 'ERP integration', 'Payment gateways', 'Inventory management'],
        callToAction: { text: 'Learn more →', href: '/services/ecommerce-solutions' },
      },
      {
        title: 'IT Consulting & Virtual CTO',
        description: `Get senior technology leadership without the full-time cost. Our Virtual CTO service helps startups and growing businesses make the right architectural decisions, manage vendors, build engineering teams, and roadmap technology that scales.`,
        icon: 'tabler:vector-triangle',
        tags: ['Tech strategy', 'Architecture review', 'Vendor management', 'Team building'],
        callToAction: { text: 'Learn more →', href: '/services/it-consulting-virtual-cto' },
      },
      {
        title: 'Cloud & Infrastructure',
        description:
          'From cloud migration to DevOps pipelines and managed hosting — we ensure your infrastructure is resilient, cost-optimized, and observable. Includes domain management, SSL, business email, and 24/7 support plans.',
        icon: 'tabler:cloud-download',
        tags: ['SSL & domains', 'Managed hosting', 'Business email', 'AWS/GCP/Azure'],
        callToAction: { text: 'Learn more →', href: '/services/cloud-infrastructure' },
      },
      {
        title: 'Community & Association Systems',
        description:
          'We build structured digital platforms for communities, associations, and trusts — enabling membership management, digital census (Vasti Patrak), directories, and engagement systems for globally connected groups.',
        icon: 'tabler:users-group',
        tags: ['Membership systems', 'Digital directory', 'Community portals', 'Vasti Patrak', 'Event management'],
        callToAction: { text: 'Learn more →', href: '/services/community-association-systems' },
      },
    ]}
  />

   <!-- Content Widget **************** -->
  <Content1
    title="From Vision to Velocity"
    subtitle="We turn complex technology challenges into competitive advantages — across AI, web, security, and growth."
    isAfterContent={false}
    items={[
      {
        title: 'Description:',
        description:
          `At Solution Planets, we combine deep research, technical expertise, and a sharp understanding of your business goals to deliver exceptional digital experiences. From custom web solutions to AI-powered tools and rock-solid security, every solution we build is engineered to drive measurable growth and long-term value for your business.`,
      },
      {
        title: 'Benefits:',
        description: `Work with a team that handles everything — web, IT, security, and AI — under one roof, so nothing falls through the cracks. Get solutions built around your specific goals, not off-the-shelf templates that compromise your brand. Scale confidently with infrastructure and products designed to grow alongside your business. <br /> Save time and reduce overhead by letting us manage the technical complexity while you focus on what you do best.`,
      },
    ]}
    image={{
      src: '',
      alt: 'Services Image',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Capabilities Built for <br /><span class="text-2xl">the Intelligence Era</span>
      </h3>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content1>

   <!-- Features Widget *************** -->
  <Features
    id="features"
    title="Why Solution Planets"
    subtitle="Built Different. Committed to Your needs."
    columns={2}
    items={[
      {
        title: 'AI-Native Approach',
        description:
          `We don't bolt AI on at the end. Every solution we design considers intelligent automation from the ground up.`,
        icon: 'tabler:hexagon-number-1',
      },
      {
        title: 'Full-Spectrum Capability',
        description: `Strategy, design, engineering, security, and marketing — under one roof, with one accountable team.`,
        icon: 'tabler:hexagon-number-2',
      },
      {
        title: 'Global, 24/7 Delivery',
        description:
          'Teams across India and the US ensure round-the-clock coverage, fast turnarounds, and cross-timezone collaboration.',
        icon: 'tabler:hexagon-number-3',
      },
      {
        title: 'Outcome-Focused Contracts',
        description: `We price and scope around your business outcomes — not hours logged. Your growth is our benchmark.`,
        icon: 'tabler:hexagon-number-4',
      },
      {
        title: 'Security by Default',
        description: `Every project we ship includes security best practices baked in — not added as an afterthought.`,
        icon: 'tabler:hexagon-number-5',
      },
      {
        title: 'Transparent & Educative',
        description: `We don't create dependency. We explain what we build, why we build it, and how you can grow with it.`,
        icon: 'tabler:hexagon-number-6',
      },
    ]}
    >
<!--     <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-slate-900" style="background-image: radial-gradient(circle, rgba(59, 130, 246, 0.1) 1px, transparent 1px); background-size: 20px 20px;"></div>
    </Fragment> -->
    </Features>
  

  <!-- Steps2 Widget ****************** -->
  <Steps2
    title="Ready to Build Something Extraordinary?"
    subtitle="Whether you're launching an MVP, scaling a platform, or hardening your cybersecurity posture — we're ready when you are."
    callToAction={{
      text: 'Contact us',
      href: '/contact',
    }}
    items={[
      {
        title: 'Email us',
        description: 'info@solutionplanets.com',
        icon: 'tabler:mail',
      },
      {
        title: 'Call us',
        description: '+91 8104664284<br />+1 (346) 829-5870',
        icon: 'tabler:headset',
      },      
    ]}
  />

</Layout>

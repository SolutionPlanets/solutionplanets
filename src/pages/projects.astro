---
import Layout from '~/layouts/PageLayout.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import Features4 from '~/components/widgets/Features4.astro';

const metadata = {
  title: 'Projects - Solution Planets',
};

const projects = [
  {
    title: 'Circulating Library Platform',
    description: 'Digitized membership, inventory, and book tracking for a physical + online library',
    impact: ['Reduced manual tracking', 'Improved member management', 'Enabled hybrid (online + offline) operations'],
    category: 'Web',
  },
  {
    title: 'Hiring & Onboarding System for Audit & Tax Firms',
    description: 'Replaced fragmented hiring processes with a structured, trackable workflow',
    impact: ['Faster hiring cycles', 'Centralized candidate management', 'Improved onboarding efficiency'],
    category: 'HR & Compliance',
  },
  {
    title: 'Digital Learning & Course Monetization System',
    description: 'Structured platform to manage content, learners, and paid course workflows',
    impact: ['Scalable learning delivery', 'Centralized user & content management', 'Integrated course revenue system'],
    category: 'EdTech',
  },
  {
    title: 'Exam Management & Assessment System',
    description: 'Structured platform to manage question banks, remote tests, and evaluation workflows',
    impact: ['Scalable online test execution', 'Centralized question bank control', 'Faster and accurate evaluation'],
    category: 'EdTech',
  },
  {
    title: 'End-to-End Business Operations System (ERP)',
    description: 'Unified platform to manage sales, production, inventory, finance, and logistics workflows',
    impact: ['Complete operational visibility', 'Reduced process delays and dependencies', 'Real-time business insights for decision making'],
    category: 'Enterprise',
  },
  {
    title: 'Multi-Channel eCommerce & Sales System',
    description: 'Structured platform to manage storefront, orders, and social selling workflows',
    impact: ['Centralized sales and order visibility', 'Improved fulfillment efficiency', 'Scalable online and social commerce'],
    category: 'eCommerce',
  },
  {
    title: 'Ind-AS Accounting & Compliance System',
    description: 'Structured financial platform to manage accounting workflows, access control, and compliance requirements',
    impact: ['Standardized Ind-AS aligned processes', 'Improved governance and financial control', 'Scalable and secure financial operations'],
    category: 'Finance & Compliance',
  },
  {
    title: 'Legal Intelligence & Statutes Management System',
    description: 'Designed a large-scale knowledge platform to organize, search, and navigate Indian legal and accounting content',
    impact: ['Centralized multi-domain legal repository', 'AI-driven cross-linking and contextual navigation', 'Faster research and improved usability', 'Scalable and structured knowledge access'],
    category: 'Legal Tech',
  },
  {
    title: 'Annual Report Compliance & Disclosure Mapping System',
    description: 'Designed a system to link statutory disclosure requirements with applicable laws and accounting standards',
    impact: ['Standardized compliance referencing', 'Faster annual report preparation', 'Reduced dependency on manual checks', 'Improved governance and reporting accuracy'],
    category: 'Compliance',
  },
  {
    title: 'Vendor Onboarding & KYC Compliance System',
    description: 'Designed a centralized platform to manage vendor registration, document verification, and approval workflows',
    impact: ['Structured and auditable onboarding process', 'Improved KYC compliance and data accuracy', 'Reduced onboarding cycle time', 'Enhanced visibility across vendor network'],
    category: 'Compliance',
  },
  {
    title: 'Content Aggregation & OTT Distribution System',
    description: 'Designed a platform to manage film rights, distribution workflows, and financial integration with OTT ecosystems',
    impact: ['Centralized content and rights management', 'Seamless integration with OTT partner systems', 'Automated revenue tracking and reconciliation', 'Scalable global distribution operations'],
    category: 'Media & Entertainment',
  },
  {
    title: 'Online Trading Academy Management System',
    description: 'Built an integrated system to manage leads, classroom operations, onboarding, and financial workflows',
    impact: ['Streamlined lead-to-enrollment process', 'Improved classroom and batch management', 'Centralized accounting and reporting', 'Enhanced visibility across operations'],
    category: 'EdTech',
  },
  {
    title: 'Procurement Workflow & Approval System',
    description: 'Built a structured system to manage procurement requests, approvals, and access control with SAP integration',
    impact: ['Standardized procurement workflows', 'Improved approval visibility and control', 'Reduced manual coordination and delays', 'Seamless integration with SAP ERP'],
    category: 'Operations',
  },
  {
    title: 'Equity Brokerage Operations System',
    description: 'Built a high-volume system to manage brokerage workflows, financial calculations, and data processing',
    impact: ['Automated complex brokerage calculations', 'Streamlined workflow and data handling', 'Improved accuracy and processing efficiency', 'Enabled scalable transaction management'],
    category: 'Finance',
  },
  {
    title: 'CNG Cylinder Testing & Certification System',
    description: 'Built a centralized platform to manage certification, compliance, and verification for authorized testing centers',
    impact: ['Standardized certification and reporting processes', 'Enabled QR-based verification for authorities and stations', 'Improved compliance tracking and control', 'Reduced manual documentation and errors'],
    category: 'Compliance',
  },
  {
    title: 'Manufacturing ERP & Production Management System',
    description: 'Built an integrated system to manage sales, production planning, inventory, and financial workflows',
    impact: ['End-to-end visibility from order to dispatch', 'Improved production planning and control', 'Reduced inventory gaps and delays', 'Centralized financial and operational reporting'],
    category: 'Manufacturing',
  },
  {
    title: 'Business Website & CMS Systems',
    description: 'Designed and developed customized websites with tailored content management systems aligned to each business requirement',
    impact: ['Structured content and brand presence', 'Easy content updates without technical dependency', 'Scalable and secure web platforms', 'Integrated with business workflows where required'],
    category: 'Web',
  },
  {
    title: 'Event Ticketing & Booking System',
    description: 'Built an integrated module to manage event registrations, ticket booking, and online payments',
    impact: ['Streamlined event booking and user experience', 'Enabled online ticket sales and payment collection', 'Reduced manual coordination and entry', 'Real-time visibility on registrations and revenue'],
    category: 'Events',
  },
  {
    title: 'Association Membership & Management System',
    description: 'Built digital platforms for organizations to manage members, events, and engagement through a structured system',
    impact: ['Automated membership registration and renewals', 'Centralized member database and communication', 'Integrated event and activity management', 'Reduced manual administration and follow-ups'],
    category: 'Community',
  },
  {
    title: 'Healthcare Provider Website Platform',
    description: 'Developed a professional web platform for doctors and dentists featuring online appointment scheduling and integrated payment processing',
    impact: ['Enabled patients to book appointments online 24/7', 'Streamlined scheduling for multi-provider practices', 'Integrated secure payment collection for consultations and treatments', 'Reduced front-desk workload through automated confirmations and reminders'],
    category: 'Healthcare',
  },
];

---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero2
    id="hero2"
    tagline="Built by our experts"
    title="Real Systems. Real Outcomes."
    actions={[{ variant: 'primary', text: 'View Case Studies', href: '#portfolio', icon: 'tabler:arrow-down' }]}
  >
    <Fragment slot="subtitle">
      We design and build business systems — from workflow automation to AI-driven platforms — that improve efficiency, visibility, and growth.
    </Fragment>
  </Hero2>

  <!-- Portfolio Grid **************** -->

  <Features4
    id="portfolio"
    title="Our Portfolio"
    subtitle="Real systems built for real business challenges — across industries, workflows, and scale."
    variant="portfolio"
    columns={2}
    items={projects}
    classes={{ container: 'max-w-7xl mx-auto', headline: { container: 'max-w-4xl' } }}
    filters={[
      { label: 'All',       categories: [] },
      { label: 'ERP',       categories: ['Enterprise', 'Manufacturing', 'Operations'] },
      { label: 'EdTech',    categories: ['EdTech'] },
      { label: 'Finance',   categories: ['Finance', 'Finance & Compliance', 'Compliance', 'HR & Compliance', 'Legal Tech'] },
      { label: 'Ecommerce', categories: ['eCommerce', 'Events', 'Entertainment'] },
      { label: 'Healthcare',     categories: ['Healthcare'] },
    ]}
  />

  <!-- What We Solve ***************** -->

  <Features4
    id="what-we-solve"
    title="What We Solve"
    subtitle="We turn common business pain points into structured, scalable solutions."
    variant="solutions"
    columns={2}
    classes={{ container: 'max-w-5xl mx-auto' }}
    items={[
      {
        icon: 'tabler:settings',
        iconBgClass: 'bg-orange-100 dark:bg-orange-900/30',
        iconColorClass: 'text-orange-500',
        before: 'Manual processes',
        after: 'Automated workflows',
      },
      {
        icon: 'tabler:database',
        iconBgClass: 'bg-blue-100 dark:bg-blue-900/30',
        iconColorClass: 'text-blue-500',
        before: 'Scattered data',
        after: 'Centralized systems',
      },
      {
        icon: 'tabler:chart-bar',
        iconBgClass: 'bg-purple-100 dark:bg-purple-900/30',
        iconColorClass: 'text-purple-500',
        before: 'Delayed decisions',
        after: 'Real-time visibility',
      },
      {
        icon: 'tabler:circle-check',
        iconBgClass: 'bg-emerald-100 dark:bg-emerald-900/30',
        iconColorClass: 'text-emerald-500',
        before: 'Missed follow-ups',
        after: 'Structured execution',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-slate-800/60"></div>
    </Fragment>
  </Features4>

  <!-- Our Platforms Widget ********** -->

  <Features4
    title="Our Platforms & Products"
    subtitle="Built by Solution Planets<span class='text-base block mt-3'>We don't just build systems for clients —<br class=&quot;hidden sm:block&quot; /> we also build and operate our own platforms across compliance, operations, and consumer ecosystems.</span>"
    variant="platforms"
    columns={3}
    items={[
      { title: 'Calibro', category: 'Calibration Compliance System', description: 'Automates calibration tracking, alerts, and audit readiness', href: 'https://www.calibrotech.com/' },
      { title: 'DonationReceipt', category: 'NGO Receipt & Compliance System', description: 'Simplifies donation tracking and 80G receipt generation', href: 'https://donationreceipt.in/' },
      { title: 'Zonect', category: 'Society Staff Management Platform', description: 'Centralized documentation and verification system for housing societies', href: 'https://zonect.in/' },
      { title: 'Credibl5', category: 'Google Review Management Tool', description: 'Automates review responses with AI and templates', href: 'https://www.credibl5.com/' },
      { title: 'HRBlues', category: 'HR Verification & Reporting Platform', description: 'Tracks employment credibility and hiring transparency', href: 'https://hrblues.in/' },
      { title: 'MatchEase', category: 'Matrimonial Matching Platform', description: 'Structured matchmaking system with preference-based filtering', href: 'https://matchease.in/' },
      { title: 'MyCricJourney', category: 'Cricket Profile & Stats Platform', description: 'Tracks performance for non-professional cricketers', href: 'https://www.mycricjourney.com/' },
      { title: 'FamilyRiwaz', category: 'Cultural Documentation Platform', description: 'Preserves family traditions and lineage digitally', href: 'https://familyriwaz.in/' },
      { title: 'The Hungry Traveller', category: 'Travel & Food Discovery Platform', description: 'Curated travel and food experiences', href: 'https://thehungrytraveller.in/' },
    ]}
  />

  <!-- Testimonials Widget *********** -->

  <Testimonials
    title="Client Testimonials"
    subtitle="Discover what clients have to say about their experiences working with us."
    testimonials={[
      {
        testimonial: `Solution Planets has been an excellent web product development partner, having worked closely with them on four different projects. They have almost always managed timely delivery of milestones as per agreed schedule. The experience of people I've referred them to has also been good - the best indicator of which is their repeat orders.`,
        name: 'Rajesh Haldipur',
        job: 'Former Head, Tax and Regulatory services',
        image: {
          src: '~/assets/images/dp/dp1.png',
          alt: 'DP Image',
        },
      },
      {
        testimonial: `We are really happy with the service provided by Dharmesh bhai and his team at Solution Planets! They go out of their way to help clients with their tech needs and are very sharp when it comes to understanding & conceptualising what exactly a client wants in a product from a technology perspective! Also, hands down, they are the most reliable tech partners I have ever worked with! Kudos to their entire team!`,
        name: 'Tanaya Doshi',
        job: 'VP Strategy - Realtime Taxsutra Services',
        image: {
          src: '~/assets/images/dp/dp2.png',
          alt: 'DP Image',
        },
      },
      {
        testimonial: `We have been associated with Solution Planets for more than a decade. We are very much satisfied and happy with their services and relationship. In fact we are now a family. I wish people get associated with them and can enjoy the long lasting business partnership with them.`,
        name: 'Pankaj Sanghavi',
        job: 'Chartered Acountant',
        image: {
          src: '~/assets/images/dp/dp3.png',
          alt: 'DP Image',
        },
      },
      {
        testimonial: `Team at Solution Planets, are people with on-ground reality; understanding client perspectives, being adaptable with quick responses, and setting realistic expectations. It has helped us in building our back office operations per our requirement! Thank You.`,
        name: 'Amit Doshi',
        job: 'Investment Director, Care Portfolio Managers',
        image: {
          src: '~/assets/images/dp/dp4.png',
          alt: 'DP Image',
        },
      },
      {
        testimonial: `We have contracted Solutions Planet to develop various software for us over the past years, and we have been more than satisfied with their performance. Their understanding the client requirements, implicating those in development and giving user friendly application is standing them out from others. Their work has always been professional and accurate. We will not hesitate to utilize their services in our future project.`,
        name: 'Bharat Jagnani',
        job: 'QESS India',
        image: {
          src: '~/assets/images/dp/dp5.png',
          alt: 'DP Imagee',
        },
      },
      {
        testimonial: `During lockdown, we shifted our mail from our in-house dedicated mail server to Microsoft. Dharmeshbhai and his team made sure of a seamless experience, minimum downtime and also helped us retain and access our old email data easily. The team also helped us taking our data to cloud from local storage and raised our queries with Microsoft personnel on our behalf. There is a visible improvement in our communication and productivity.`,
        name: 'Siddharth Zaveri',
        job: 'Director, Mahavir Hydraulics Pvt Ltd',
        image: {
          src: '~/assets/images/dp/dp6.png',
          alt: 'DP Image',
        },
      },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    title="Let's Solve a Real Business Problem"
    subtitle="Whether it's automation, AI, or system design — we help you identify where technology actually drives results."
    actions={[
      {
        variant: 'primary',
        text: 'Book a Discussion',
        href: '/contact',
      },
    ]}
  />
</Layout>

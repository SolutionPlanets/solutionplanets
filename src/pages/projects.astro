---
import Layout from '~/layouts/PageLayout.astro';

//import Header from '~/components/widgets/Header.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
//import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
//import Steps from '~/components/widgets/Steps.astro';
//import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
//import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'Products - Solution Planets',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero2
    id="hero2"
    title="From Idea to Online"
    tagline="Built by our experts"
    actions={[{ variant: 'primary', text: 'Portfolio', href: '#features3', icon: 'tabler:arrow-down', }]}
  >
    <Fragment slot="subtitle">
      We are dedicated to providing top-notch digital solutions for your business. Our team of experienced professionals leverages cutting-edge technologies and best practices to deliver tailor-made software solutions that meet your unique needs.
    </Fragment>
  </Hero2>
    
  <!-- Features3 Widget ************** -->

  <Features3
    id='features3'
    title="Our Portfolio"
    subtitle="We are your partner in digital evolution, providing tech that adapts as you do. We define our success through technology that helps you grow."
    columns={3}
    defaultIcon="tabler:point-filled"
    items={[
      {
        title: 'Circulating Library',
        description: 'Platform for online and in-store library registration, and upcycling system for books and toys',
      },
      {
        title: 'Placement Portal',
        description: 'A niche placement portal for Audit/Taxation firms for hiring and onboarding process',
      },
      {
        title: 'Learning Management Platform',
        description: 'LMS platform with content management, profile management, and course purchase',
      },
      {
        title: 'Online Test portal',
        description: 'Portal for coaching class to manage question banks, and run tests remotly',
      },
      {
        title: 'Enterprise resource planning',
        description: 'CRM, Orders, Production Control and quality check, Inventory Management, Accounting, Logistics and Reporting',
      },
      {
        title: 'eCommerce and eStore',
        description: 'Manage sales from one dashboard. Complete eStore designing and selling on social media',
      },
      /* {
        title: 'Print and digital design',
        description: 'Knowledgeable in designing for both print materials and digital platforms.',

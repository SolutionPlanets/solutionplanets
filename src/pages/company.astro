---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Features from '~/components/widgets/Features.astro';
import Features3 from '~/components/widgets/Features3.astro';

const metadata = {
  title: 'About - Solution Planets',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->
  <Hero2
    tagline="Our Origin & Evolution"
    actions={[
      {
        variant: 'primary',
        target: '',
        text: 'More About Us',
        href: '#features3',
        icon: 'tabler:arrow-down',
      },
      { text: 'Connect With Us', 
        href: 'https://www.linkedin.com/company/solutionplanets/', 
        target: '_blank',
        icon: 'tabler:brand-linkedin',
     },
    ]}
  >
    <Fragment slot="title">
      Digital Systems
      <span class="hidden sm:inline"></span>
      <span class="text-accent dark:text-white"></span>
      for Growing Enterprises
    </Fragment>

    <Fragment slot="subtitle">
      We design, build, and implement <span class="font-semibold">custom engineering solutions</span> and focused SaaS platforms that strengthen workflow, compliance, and operational visibility.
    </Fragment>   
  </Hero2>

  <Hero
    tagline="About us"
      showArora={true}
  aroraId="aurora-about"
  >
    <Fragment slot="title">
      Solution Planets
    </Fragment>

    <Fragment slot="subtitle">
      We are digital engineering company focused on designing and building structured, scalable systems for growing enterprises. Founded at the intersection of technology and operational discipline, we work with organizations that have outgrown informal processes and need clarity, control, and long-term architecture.
    </Fragment>
  </Hero>

  <!-- Steps2 Widget ****************** -->
  <Steps2
    id="steps2"
    title='Our Values'
    subtitle="We believe in digital systems that reduce friction, prevent leakage, and strengthen execution discipline. At Solution Planets, We are not just a technology. We are long-term partners in building durable, scalable digital foundations. Our Work philosophy is simple 4 steps:"
    items={[
      { title: 'Understand the business architecture before writing code' },
      { title: 'Define ownership and decision pathways clearly' },
      { title: 'Embed control mechanisms into workflows' },
      { title: 'Build systems that scale with growth' },
    ]}
  />
  <Steps2
    title="Core Speciality"
    subtitle="We don’t believe in software for the sake of features. We specialize in two core areas, digital engineering and SaaS platforms Check out our projects."
    isReversed={true}
    callToAction={{
      text: 'See Our Work',
      href: '/projects',
    }}
    items={[
      {
        title: 'Custom Digital Engineering',
        description:
          'We design and develop tailored software systems aligned to real business workflows — ensuring visibility, ownership, and operational efficiency across functions.',
        icon: 'tabler:message-star',
      },       
      {
        title: 'Focused SaaS Platforms',
        description:
          'We build purpose-driven digital platforms that address specific operational gaps in compliance, governance, process control, and business automation.',
        icon: 'tabler:message-star',
      },
    ]}
  />

  <!-- Features Widget ************** -->
  <Features
    title="Our Engineering Framework"
    subtitle="Building digital systems that scale requires more than coding. It requires architectural clarity and execution discipline."
    
    items={[
      {
        title: 'Business Architecture Mapping',
        description:
          'We begin by understanding your operational structure — decision flows, ownership boundaries, compliance requirements, and workflow dependencies',
        icon: 'tabler:brand-tailwind',
      },
      {
        title: 'System & Workflow Design',
         description:
          'We translate business logic into structured digital architecture — defining escalation paths, integration points, data governance, and control mechanisms.',
        icon: 'tabler:components',
      },
      {
        title: 'Controlled Implementation',
         description:
          'We engineer high-integrity software solutions — custom-built or platform-driven — ensuring alignment with real operational use cases.',
        icon: 'tabler:arrows-right-left',
      },
      {
        title: 'Governance and Continuous Optimization',
         description:
          'Systems must evolve as your business grows. We implement monitoring frameworks, performance checkpoints, and structured iteration cycles',
        icon: 'tabler:rocket',
      },
    ]}
  >
    <!-- <Fragment slot="bg">
       <div class="absolute inset-0 bg-gradient-to-br from-blue-50 via-indigo-50 to-purple-50 dark:from-slate-900 dark:via-blue-900 dark:to-slate-900"></div>
    </Fragment> -->
  </Features>

  <!-- Features2 Widget ************** -->
  <Features2
    title="Why Businesses Choose Solution Planets?"
    subtitle="We work as structured digital engineering partners — bringing clarity, discipline, and long-term thinking to every system we build."
    items={[
      {
        title: ' Strategic Before Technical',
        description:
          'Every engagement begins with architecture, workflow mapping, and business logic clarity — not immediate coding.',
        icon: 'flat-color-icons:puzzle',
      },
      {
        title: 'Systems That Scale',
        description:
          'We build structured digital systems designed to grow with your business — not quick fixes that collapse under volume',
        icon: 'flat-color-icons:positive-dynamic',
      },
      {
        title: 'Automation With Purpose',
        description:
          'AI and automation are applied where they reduce cost, improve control, and enhance measurable outcomes — not for buzzword value.',
        icon: 'flat-color-icons:process',
      },
      {
        title: 'Governance & Control Built-In',
        description:
          'Our solutions are designed with auditability, data structure, and operational discipline from day one.',
        icon: 'flat-color-icons:rating',
      },
      {
        title: 'Clear Ownership & Accountability',
        description:
          'You interact with decision-makers. Clear communication. Defined responsibility. No layered confusion.',
        icon: 'flat-color-icons:collaboration',
      },
      {
        title: 'Long-Term Technology Partnership',
        description:
          'We stay involved beyond deployment — optimizing, strengthening, and adapting systems as your business evolves.',
        icon: 'flat-color-icons:workflow',
      },
    ]}
  >
    <Fragment slot="bg">
       <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- Features3 Widget ************** -->
  <Features3
    title="Start the Conversation"
    subtitle="When you're planning digital transformation, automation, AI integration, or structured system development — let’s discuss your requirements."
    columns={4}
    items={[
      {
        title: 'Direct Consultation',
        icon: 'tabler:phone',
        callToAction: {
          target: '_blank',
          text: 'Speak with our team about your business requirements',
          href: '/contact',
          variant: 'link',
        },
      },
      {
        title: 'Business Enquiries',
        icon: 'tabler:mail',
        callToAction: {
          target: '_blank',
          text: 'Share your project details or RFP',
          href: '/contact',
          variant: 'link',
        },
      },
      {
        title: 'WhatsApp Connect',
        icon: 'tabler:message-circle',
        callToAction: {
          target: '_blank',
          text: 'Quick discussion for initial clarity',
          href: '/contact',
          variant: 'link',
        },
      },
      {
        title: 'Technical Support',
        icon: 'tabler:message-circle',
        callToAction: {
          target: '_blank',
          text: 'For existing clients and implementation assistance',
          href: '/contact',
          variant: 'link',
        },
      },
    ]}
  >
  <Fragment slot="bg">
    <!-- Pattern background -->
       <div class="absolute inset-0 bg-gradient-to-br from-blue-50 via-indigo-50 to-purple-50 dark:from-slate-900 dark:via-blue-900 dark:to-slate-900"></div>
    </Fragment>
</Features3>

  <!-- CallToAction Widget *********** -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Get Connected',
        href: 'https://wa.me/13468295870',
        target: '_blank',
        icon: 'tabler:brand-whatsapp',
      },
    ]}
  >
    <Fragment slot="title">Ready to for your next phase of growth?</Fragment>

    <Fragment slot="subtitle">
      We help growth-focused businesses build scalable digital systems, automation frameworks, and AI-enabled workflows that drive measurable outcome. Let’s discuss how Solution Planets can support your next move.
    </Fragment>
    
  </CallToAction>  
</Layout>

---
import Layout from '~/layouts/PageLayout.astro';

import Hero2 from '~/components/widgets/Hero2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

import Features2 from '~/components/widgets/Features2.astro';
//import Features from '~/components/widgets/Features.astro';
import Stats from '~/components/widgets/Stats.astro';
import Features3 from '~/components/widgets/Features3.astro';
//import Brands from '~/components/widgets/Brands.astro';

import { YouTube } from 'astro-embed';

const metadata = {
  title: 'About Company - Solution Planets',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero2
    tagline="Our Origin & Evolution"
    actions={[
      {
        variant: 'primary',
        target: '_blank',
        text: 'Explore Our Solutions',
        href: '',
        icon: '',
      },
      { text: 'Connect With Us', 
        href: 'https://www.linkedin.com/company/solutionplanets/', 
        target: '_blank',
        icon: 'tabler:brand-linkedin',

     },
    ]}
  >
    <Fragment slot="title">
      <span class="hidden sm:inline">Structured Digital Systems</span>
      <span class="text-accent dark:text-white"></span>
      for Growing Enterprises
    </Fragment>

    <Fragment slot="subtitle">
      We design, build, and implement <span class="font-semibold">custom engineering solutions</span> and focused SaaS platforms that strengthen workflow, compliance, and operational visibility.
    </Fragment>

    <Fragment slot="image">
      <YouTube id="gxBkghlglTg" title="Astro just Launched.... Could it be the ultimate web framework?" />
      <style is:inline>
        lite-youtube {
          margin: 0 auto;
          max-width: 100%;
        }
      </style>
    </Fragment>
  </Hero2>

  <!-- Features2 Widget ************** -->
  <Features2
    title="About us"
    subtitle="Solution Planets is a digital engineering company focused on designing and building structured, scalable systems for growing enterprises. Founded at the intersection of technology and operational discipline, we work with organizations that have outgrown informal processes and need clarity, control, and long-term architecture. We specialize in two core areas."
    items={[
      {
        title: 'Custom Digital Engineering',
        description:
          'We design and develop tailored software systems aligned to real business workflows — ensuring visibility, ownership, and operational efficiency across functions.',
      },
      {
        title: 'Focused SaaS Platforms',
        description:
          'We build purpose-driven digital platforms that address specific operational gaps in compliance, governance, process control, and business automation.',
      },
    ]}
  >
    <Fragment slot="bg">
       <div class="absolute inset-0 bg-gradient-to-br from-blue-50 via-indigo-50 to-purple-50 dark:from-slate-900 dark:via-blue-900 dark:to-slate-900"></div>
    </Fragment>
  </Features2>

  <!-- Stats Widget ****************** -->
  <Stats
    title='Our Engineering Framework'
    subtitle="Building digital systems that scale requires more than coding.It requires architectural clarity and execution discipline."
    stats={[
      { title: 'Identify', amount: 'Understanding the DNA of your brand and goals.' },
      { title: 'Plan & Design', amount: 'Mapping the architecture of your digital future.' },
      { title: 'Implement', amount: 'Building high-integrity software and AI-driven tools.' },
      { title: 'Nurture', amount: 'Scaling and improving your product long after launch.' },
    ]}
  />


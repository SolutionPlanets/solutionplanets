---
import Layout from '~/layouts/PageLayout.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import { getPermalink } from '~/utils/permalinks';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';


const metadata = {
  title: 'SolutionPlanets — Digital and IT partner providing web development and marketing solutions for SMBs',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  
  <!-- Hero Widget ******************* -->

  <Hero2
    tagline="Your Vision, Our Universe"
    actions={[
      {
        variant: 'primary',
        text: "Let's Chat",
        href: 'https://wa.me/13468295870',
        target: '_blank',
        icon: 'tabler:brand-whatsapp',
      },
      { text: 'Explore Services', href: getPermalink('/services') },
    ]}
    image={{ src: '~/assets/images/hero-image1.png', alt: 'SP Hero Image' }}
  >
    <Fragment slot="title">              
      <span class="text-accent dark:text-white">Structured Digital Systems</span>
      <span class="hidden xl:block">for Growing Businesses</span>         
    </Fragment>

    <Fragment slot="subtitle">
      <span class="hidden sm:inline">
        <span class="font-semibold">Solution Planets helps growth-focused companies</span> design automation frameworks, AI-enabled workflows, and scalable digital infrastructure built for long-term performance.
      </span>
      <span class="block mb-1 sm:hidden font-bold text-blue-600">Autonomous development and next-gen solutions
      for growing businesses of all sizes.</span>
    </Fragment>
  </Hero2>

  <!-- Note Widget ******************* -->

  <Note title="Philosophy:" description="Clarity in Architecture. Discipline in Execution." />

  <!-- Features Widget *************** -->

  <Features
    id="features"
    tagline="Our Framework"
    title="From Business Objectives to Structured Execution"
    subtitle="Our Strategic Orbit: We follow a disciplined methodology to translate business goals into scalable, high-performance digital systems."
    items={[
      {
        title: 'Identify',
        description:
          'We follow a disciplined methodology to translate business goals into scalable, high-performance digital systems.',
        icon: 'tabler:brand-tailwind',
      },
      {
        title: 'Analyze',
        description:
          'We map workflows, data flows, and architecture requirements to ensure clarity, scalability, and risk control. ',
        icon: 'tabler:components',
      },
            {
        title: 'Implement',
        description:
          'We build structured, high-integrity systems aligned with performance, security, and governance standards.',
        icon: 'tabler:rocket',
      },
      {
        title: 'Improve',
        description:
          'We monitor performance, optimize workflows, and refine systems to support long-term growth and operational efficiency.',
        icon: 'tabler:arrows-right-left',
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    isReversed
    title="Why Partner With US?"
    tagline="Structured Thinking. Reliable Execution."
    items={[
      {
        title: 'Security & Governance Built-In:',
        description:
          'Every system is designed with data integrity, access control, and operational discipline from day one.',
      },
      {
        title: 'Clear Communication & Ownership:',
        description:
          'Defined responsibilities, structured milestones, and transparent reporting throughout the engagement.',
      },
      {
        title: 'Designed for Scale:',
        description:
          'Systems built to handle growth — users, transactions, automation, and performance.',
      },
    ]}
    image={{
      src: '~/assets/images/feature.png', 
      alt: 'SP Foundation Image',
      loading: 'eager',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Building On Modern Foundations</h3>
      Gain a competitive advantage by incorporating industry leading practices
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Steps Widget ****************** -->

  <Steps
    title="Strategy Meets Structure"
    subtitle="We translate business strategy into structured digital architecture designed for scale, control, and performance."
    items={[
      {
        title: 'Step 1: <span class="font-medium">Architect</span>',
        description:
          "We define system architecture, workflows, and measurable objectives before development begins.",
          icon: 'tabler:package',
      },
      {
        title: 'Step 2: <span class="font-medium">Integrate</span>',
        description:
          "We connect platforms, automation layers, AI models, and data systems into a unified operational structure.",
        icon: 'tabler:letter-case',
      },
      {
        title: 'Step 3: <span class="font-medium">Calibrate</span>',
        description:
          'We test performance, security, scalability, and process efficiency before launch',
        icon: 'tabler:paint',
      },
      {
        title: 'Deploy & Support',
        description:
          "We design and implement scalable digital systems that align technology with business performance.",
        icon: 'tabler:check',
      },
    ]}
    image={{
      src: '',
      alt: 'Steps image',
    }}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    tagline="Our Services"
    subtitle="We design and implement scalable digital systems that align technology with business performance."
    title="Core Strategic Services"
    items={[
      {
        title: 'Custom Application & Platform Development',
        description: "Enterprise-grade web and system development built for scalability, integration, and performance.",
        icon: 'flat-color-icons:multiple-devices',
      },
      {
        title: 'AI & Workflow Automation',
        description:
          "Designing AI-driven processes, intelligent agents, and operational automation frameworks.",
        icon: 'flat-color-icons:process',
      },
      {
        title: 'Digital Infrastructure & Cloud Systems',
        description:
          'Secure hosting architecture, cloud deployment, workspace integration, and performance optimization.',
        icon: 'flat-color-icons:approval',
      },
      {
        title: 'Cybersecurity & Governance',
        description:
          "Multi-layered protection, access control, audit-ready frameworks, and data integrity systems.",
        icon: 'flat-color-icons:data-protection',
      },
      {
        title: 'Strategic Technology Advisory (Virtual CTO)',
        description:
          'Architecture planning, tech stack decisions, vendor evaluation, and long-term digital roadmap alignment.',
        icon: 'flat-color-icons:mind-map',
      },
      {
        title: 'Supporting Digital Services',
        description:
          'Delivering services for businesses that need specialized execution to complement and accelerate wider digital transformations.',
        icon: 'flat-color-icons:link',
      },   
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>
  <!-- component Widget ************** -->
    <Content
    id="Supporting Services"
    columns={1}
    items={[
      {
        icon: 'tabler:brand-dribbble',
        callToAction: {
          text: 'Web Design & Development',
        },
      },
      {
        icon: 'tabler:cloud-search',
        callToAction: {
          text: 'SEO & AI Search Optimization',
        },
      },
      {
        icon: 'tabler:ad-circle',
        callToAction: {
          text: 'Performance Marketing',
        },
      },
      {
        icon: 'tabler:link',
        callToAction: {
          text: 'Domain & Hosting Setup',
        },
      },
      {
        icon: 'tabler:shopping-cart',
        callToAction: {
          text: 'E-commerce Enablement',
        },
      },
    ]}
    image={{
      src: '~/assets/images/services.jpeg',
      alt: 'Service Image',
      loading: 'eager',
    }}
  >
    <Fragment slot="content">
      <h2 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Other Supporting Services</h2>
      For businesses that need focused execution alongside larger digital initiatives.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Schedule a Meeting',
        href: 'https://wa.me/13468295870',
        target: '_blank',
        icon: 'tabler:brand-whatsapp',
      },
    ]}
  >
    <Fragment slot="title">
      Ready for&nbsp;<br class="block sm:hidden" /><span class="sm:whitespace-nowrap">your next phase of growth?</span>
    </Fragment>

    <Fragment slot="subtitle">
      We help businesses translate strategy into scalable digital systems — automation, AI, infrastructure, and governance aligned with real performance outcomes.
    </Fragment>
  </CallToAction>

  <!-- Stats Widget ****************** -->

  <Stats
    stats={[
      { title: 'Clients Served', amount: '132' },
      { title: 'Projects Delivered', amount: '248' },
      { title: 'Years of Experience', amount: '15' },
      { title: 'Active Products', amount: '8' },
    ]}
  /> 
  
</Layout>


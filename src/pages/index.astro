---
import Layout from '~/layouts/PageLayout.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import { getPermalink } from '~/utils/permalinks';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';


const metadata = {
  title: 'SolutionPlanets — Digital and IT partner providing web development and marketing solutions for SMBs',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  
  <!-- Hero Widget ******************* -->

  <Hero2
    tagline="Your Vision, Our Universe"
    actions={[
      {
        variant: 'primary',
        text: "Let's Chat",
        href: 'https://wa.me/13468295870',
        target: '_blank',
        icon: 'tabler:brand-whatsapp',
      },
      { text: 'Explore Services', href: getPermalink('/services') },
    ]}
    image={{ src: '~/assets/images/hero-image1.png', alt: 'SP Hero Image' }}
  >
    <Fragment slot="title">              
      <span class="text-accent dark:text-white">Digital Solutions for Growing Businesses</span>
      <span class="hidden xl:block"></span>         
    </Fragment>

    <Fragment slot="subtitle">
      <span class="hidden sm:inline">
        <span class="font-semibold">Solution Planets helps growth-focused companies</span> design automation frameworks, AI-enabled workflows, and scalable digital infrastructure built for long-term performance.
      </span>
      Autonomous development and next-gen solutions for businesses of all sizes.
      <span class="block mb-1 sm:hidden font-bold text-blue-600">---</span>
    </Fragment>
  </Hero2>

  <!-- Note Widget ******************* -->

  <Note title="Philosophy:" description="Clarity in Architecture. Discipline in Execution." />

  <!-- Features Widget *************** -->

  <Features
    id="features"
    tagline="Our Framework"
    title="From Business Objectives to Structured Execution"
    subtitle="Our Strategic Orbit: We follow a disciplined methodology to translate business goals into scalable, high-performance digital systems."
    items={[
      {
        title: 'Identify',
        description:
          'We follow a disciplined methodology to translate business goals into scalable, high-performance digital systems.',
        icon: 'tabler:brand-tailwind',
      },
      {
        title: 'Analyze',
        description:
          'We map workflows, data flows, and architecture requirements to ensure clarity, scalability, and risk control. ',
        icon: 'tabler:components',
      },
            {
        title: 'Implement',
        description:
          'We build structured, high-integrity systems aligned with performance, security, and governance standards.',
        icon: 'tabler:rocket',
      },
      {
        title: 'Improve',
        description:
          'We monitor performance, optimize workflows, and refine systems to support long-term growth and operational efficiency.',
        icon: 'tabler:arrows-right-left',
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    isReversed
    title="Why Partner With US?"
    tagline="Structured Thinking. Reliable Execution."
    items={[
      {
        title: 'Security & Governance Built-In:',
        description:
          'Every system is designed with data integrity, access control, and operational discipline from day one.',
      },
      {
        title: 'Clear Communication & Ownership:',
        description:
          'Defined responsibilities, structured milestones, and transparent reporting throughout the engagement.',
      },
      {
        title: 'Designed for Scale:',
        description:
          'Systems built to handle growth — users, transactions, automation, and performance.',
      },
    ]}
    image={{
      src: '~/assets/images/feature.png', 
      alt: 'SP Foundation Image',
      loading: 'eager',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Modern, Proven Technology Stack</h3>
     We work with stable, well-supported frameworks and infrastructure — ensuring long-term reliability and maintainability.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Steps Widget ****************** -->

  <Steps
    title="Strategy Meets Structure"
    subtitle="We translate business strategy into structured digital architecture designed for scale, control, and performance."
    items={[
      {
        title: 'Step 1: <span class="font-medium">Architect</span>',
        description:
          "We define system architecture, workflows, and measurable objectives before development begins.",
          icon: 'tabler:package',
      },
      {
        title: 'Step 2: <span class="font-medium">Integrate</span>',
        description:
          "We connect platforms, automation layers, AI models, and data systems into a unified operational structure.",
        icon: 'tabler:letter-case',
      },
      {
        title: 'Step 3: <span class="font-medium">Calibrate</span>',
        description:
          'We test performance, security, scalability, and process efficiency before launch',
        icon: 'tabler:paint',
      },
      {
        title: 'Deploy & Support',
        description:
          "We design and implement scalable digital systems that align technology with business performance.",
        icon: 'tabler:check',
      },
    ]}
    image={{
      src: '',
      alt: 'Steps image',
    }}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    tagline="Our Services"
    subtitle="We design and implement scalable digital systems that align technology with business performance."
    title="Core Strategic Services"
    items={[
      {
        title: 'Custom Application & Platform Development',
        description: "Enterprise-grade web and system development built for scalability, integration, and performance.",
        icon: 'flat-color-icons:multiple-devices',
      },
      {
        title: 'AI & Workflow Automation',
        description:
          "Designing AI-driven processes, intelligent agents, and operational automation frameworks.",
        icon: 'flat-color-icons:process',
      },
      {
        title: 'Digital Infrastructure & Cloud Systems',
        description:
          'Secure hosting architecture, cloud deployment, workspace integration, and performance optimization.',
        icon: 'flat-color-icons:approval',
      },
      {
        title: 'Cybersecurity & Governance',
        description:
          "Multi-layered protection, access control, audit-ready frameworks, and data integrity systems.",
        icon: 'flat-color-icons:data-protection',
      },
      {
        title: 'Strategic Technology Advisory (Virtual CTO)',
        description:
          'Architecture planning, tech stack decisions, vendor evaluation, and long-term digital roadmap alignment.',
        icon: 'flat-color-icons:mind-map',
      },
      {
        title: 'Supporting Digital Services',
        description:
          'Delivering services for businesses that need specialized execution to complement and accelerate wider digital transformations.',
        icon: 'flat-color-icons:link',
      },   
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>
  <!-- component Widget ************** -->
    <Content
    id="Supporting Services"
    columns={1}
    items={[
      {
        icon: 'tabler:brand-dribbble',
        callToAction: {
          text: 'Web Design & Development',
        },
      },
      {
        icon: 'tabler:cloud-search',
        callToAction: {
          text: 'SEO & AI Search Optimization',
        },
      },
      {
        icon: 'tabler:ad-circle',
        callToAction: {
          text: 'Performance Marketing',
        },
      },
      {
        icon: 'tabler:link',
        callToAction: {
          text: 'Domain & Hosting Setup',
        },
      },
      {
        icon: 'tabler:shopping-cart',
        callToAction: {
          text: 'E-commerce Enablement',
        },
      },
    ]}
    image={{
      src: '~/assets/images/services.jpeg',
      alt: 'Service Image',
      loading: 'eager',
    }}
  >
    <Fragment slot="content">
      <h2 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Other Supporting Services</h2>
      For businesses that need focused execution alongside larger digital initiatives.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>


  <!-- Our Platforms Widget ********** -->

  <section class="relative not-prose scroll-mt-[72px]">
    <div class="relative mx-auto max-w-7xl px-4 md:px-6 py-12 md:py-16 lg:py-20 text-default">
      <div class="mb-8 md:mx-auto md:mb-12 text-center max-w-3xl">
        <h2 class="font-bold leading-tighter tracking-tighter font-heading text-heading text-3xl md:text-4xl">
          Our Platforms & Products
        </h2>
        <p class="mt-4 text-muted text-xl">
          Built by Solution Planets
        </p>
        <p class="mt-3 text-muted text-base">
          We don't just build systems for clients —<br class="hidden sm:block" />
          we also build and operate our own platforms across compliance, operations, and consumer ecosystems.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 mt-10">
        <a href="https://www.calibrotech.com/" target="_blank" rel="noopener noreferrer" class="group rounded-xl border border-slate-200 dark:border-slate-700 border-t-2 border-t-orange-500 bg-white dark:bg-slate-900 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-300 p-6 flex flex-col gap-3">
          <div class="flex items-center justify-between">
            <span class="text-xl font-extrabold text-slate-900 dark:text-white tracking-tight">Calibro</span>
            <svg class="w-4 h-4 text-slate-400 group-hover:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg>
          </div>
          <p class="text-xs font-semibold uppercase tracking-wider text-primary">Calibration Compliance System</p>
          <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">Automates calibration tracking, alerts, and audit readiness</p>
        </a>

        <a href="https://donationreceipt.in/" target="_blank" rel="noopener noreferrer" class="group rounded-xl border border-slate-200 dark:border-slate-700 border-t-2 border-t-orange-500 bg-white dark:bg-slate-900 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-300 p-6 flex flex-col gap-3">
          <div class="flex items-center justify-between">
            <span class="text-xl font-extrabold text-slate-900 dark:text-white tracking-tight">DonationReceipt</span>
            <svg class="w-4 h-4 text-slate-400 group-hover:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg>
          </div>
          <p class="text-xs font-semibold uppercase tracking-wider text-primary">NGO Receipt & Compliance System</p>
          <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">Simplifies donation tracking and 80G receipt generation</p>
        </a>

        <a href="https://zonect.in/" target="_blank" rel="noopener noreferrer" class="group rounded-xl border border-slate-200 dark:border-slate-700 border-t-2 border-t-orange-500 bg-white dark:bg-slate-900 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-300 p-6 flex flex-col gap-3">
          <div class="flex items-center justify-between">
            <span class="text-xl font-extrabold text-slate-900 dark:text-white tracking-tight">Zonect</span>
            <svg class="w-4 h-4 text-slate-400 group-hover:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg>
          </div>
          <p class="text-xs font-semibold uppercase tracking-wider text-primary">Society Staff Management Platform</p>
          <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">Centralized documentation and verification system for housing societies</p>
        </a>

        <a href="https://www.credibl5.com/" target="_blank" rel="noopener noreferrer" class="group rounded-xl border border-slate-200 dark:border-slate-700 border-t-2 border-t-orange-500 bg-white dark:bg-slate-900 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-300 p-6 flex flex-col gap-3">
          <div class="flex items-center justify-between">
            <span class="text-xl font-extrabold text-slate-900 dark:text-white tracking-tight">Credibl5</span>
            <svg class="w-4 h-4 text-slate-400 group-hover:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg>
          </div>
          <p class="text-xs font-semibold uppercase tracking-wider text-primary">Google Review Management Tool</p>
          <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">Automates review responses with AI and templates</p>
        </a>

        <a href="https://hrblues.in/" target="_blank" rel="noopener noreferrer" class="group rounded-xl border border-slate-200 dark:border-slate-700 border-t-2 border-t-orange-500 bg-white dark:bg-slate-900 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-300 p-6 flex flex-col gap-3">
          <div class="flex items-center justify-between">
            <span class="text-xl font-extrabold text-slate-900 dark:text-white tracking-tight">HRBlues</span>
            <svg class="w-4 h-4 text-slate-400 group-hover:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg>
          </div>
          <p class="text-xs font-semibold uppercase tracking-wider text-primary">HR Verification & Reporting Platform</p>
          <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">Tracks employment credibility and hiring transparency</p>
        </a>

        <a href="https://matchease.in/" target="_blank" rel="noopener noreferrer" class="group rounded-xl border border-slate-200 dark:border-slate-700 border-t-2 border-t-orange-500 bg-white dark:bg-slate-900 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-300 p-6 flex flex-col gap-3">
          <div class="flex items-center justify-between">
            <span class="text-xl font-extrabold text-slate-900 dark:text-white tracking-tight">MatchEase</span>
            <svg class="w-4 h-4 text-slate-400 group-hover:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg>
          </div>
          <p class="text-xs font-semibold uppercase tracking-wider text-primary">Matrimonial Matching Platform</p>
          <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">Structured matchmaking system with preference-based filtering</p>
        </a>

        <a href="https://www.mycricjourney.com/" target="_blank" rel="noopener noreferrer" class="group rounded-xl border border-slate-200 dark:border-slate-700 border-t-2 border-t-orange-500 bg-white dark:bg-slate-900 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-300 p-6 flex flex-col gap-3">
          <div class="flex items-center justify-between">
            <span class="text-xl font-extrabold text-slate-900 dark:text-white tracking-tight">MyCricJourney</span>
            <svg class="w-4 h-4 text-slate-400 group-hover:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg>
          </div>
          <p class="text-xs font-semibold uppercase tracking-wider text-primary">Cricket Profile & Stats Platform</p>
          <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">Tracks performance for non-professional cricketers</p>
        </a>

        <a href="https://familyriwaz.in/" target="_blank" rel="noopener noreferrer" class="group rounded-xl border border-slate-200 dark:border-slate-700 border-t-2 border-t-orange-500 bg-white dark:bg-slate-900 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-300 p-6 flex flex-col gap-3">
          <div class="flex items-center justify-between">
            <span class="text-xl font-extrabold text-slate-900 dark:text-white tracking-tight">FamilyRiwaz</span>
            <svg class="w-4 h-4 text-slate-400 group-hover:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg>
          </div>
          <p class="text-xs font-semibold uppercase tracking-wider text-primary">Cultural Documentation Platform</p>
          <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">Preserves family traditions and lineage digitally</p>
        </a>

        <a href="https://thehungrytraveller.in/" target="_blank" rel="noopener noreferrer" class="group rounded-xl border border-slate-200 dark:border-slate-700 border-t-2 border-t-orange-500 bg-white dark:bg-slate-900 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-300 p-6 flex flex-col gap-3">
          <div class="flex items-center justify-between">
            <span class="text-xl font-extrabold text-slate-900 dark:text-white tracking-tight">The Hungry Traveller</span>
            <svg class="w-4 h-4 text-slate-400 group-hover:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg>
          </div>
          <p class="text-xs font-semibold uppercase tracking-wider text-primary">Travel & Food Discovery Platform</p>
          <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">Curated travel and food experiences</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Stats Widget ****************** -->
  <Stats
    stats={[
      { title: 'Projects Delivered', amount: '250+' },
      { title: 'Clients Served', amount: '130+' },      
      { title: 'Combined Experience', amount: '20+' },
      { title: 'Our Products', amount: '5+' },
    ]}
  /> 

  <!-- CallToAction Widget *********** -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Schedule a Meeting',
        href: 'https://wa.me/13468295870',
        target: '_blank',
        icon: 'tabler:brand-whatsapp',
      },
    ]}
  >
    <Fragment slot="title">
      Ready for&nbsp;<br class="block sm:hidden" /><span class="sm:whitespace-nowrap">your next phase of growth?</span>
    </Fragment>

    <Fragment slot="subtitle">
      We help businesses translate strategy into scalable digital systems — automation, AI, infrastructure, and governance aligned with real performance outcomes.
    </Fragment>
  </CallToAction> 
  
</Layout>

